# Upstash Redis (create a free database at https://console.upstash.com)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Resend (create a free API key at https://resend.com/api-keys)
RESEND_API_KEY=
# Must be a verified sender on your Resend account/domain, or the default sandbox address below
EMAIL_FROM="Gramafin <onboarding@resend.dev>"

# Sanity (Help Center CMS — create a free project at https://sanity.io)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
